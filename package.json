  "author": {
    "name": "Real Vibecode Project"
  },
  "license": "UNLICENSED",
  "description": "AI-native IDE built on VS Code with multi-provider LLM support and autonomous execution",
  "main": "./out/main.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Razisafir/Real-vibecode.git"
  },
  "bugs": {
