  "scripts": {
    "build:desktop": "bash scripts/build-desktop.sh",
    "build:desktop:win": "bash scripts/build-desktop.sh --platform win",
    "build:desktop:mac": "bash scripts/build-desktop.sh --platform mac",
    "build:desktop:linux": "bash scripts/build-desktop.sh --platform linux",
    "build:desktop:all": "bash scripts/build-desktop.sh --platform all",
    "build:desktop:clean": "bash scripts/build-desktop.sh --clean",
    "package": "npx electron-builder",
