<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT compilation for V8 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (required for V8/WebAssembly) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading dynamically-linked libraries (extensions, native modules) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access for extensions, updates, and remote features -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access for opening/saving projects and files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow debugging (development) -->
    <key>com.apple.security.get-task-allow</key>
    <true/>

    <!-- Allow sending Apple Events for terminal/shell integration -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
